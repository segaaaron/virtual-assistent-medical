# --- Loreley Brain — variables de entorno (copiar a .env, NUNCA commitear .env) ---

NODE_ENV=development
PORT=3000

# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=1225614367293269
WHATSAPP_TOKEN=                 # System User token PERMANENTE (rotar el viejo, estaba comprometido)
WHATSAPP_APP_SECRET=            # para verificar X-Hub-Signature-256
WHATSAPP_VERIFY_TOKEN=          # token de verificacion del webhook (lo eliges tu)
WHATSAPP_GRAPH_VERSION=v21.0

# OpenAI
OPENAI_API_KEY=

# Datos privados de la doctora (NUNCA commitear valores reales; solo en .env)
DOCTORA_PHONE=                 # numero personal de la Dra (allow-list + escalacion), E.164 sin "+"
DOCTORA_NAME=                  # nombre completo de la doctora, ej. "Nombre Apellido"

# PostgreSQL
DATABASE_URL=postgres://user:pass@localhost:5432/loreley

# Redis (cola BullMQ)
REDIS_URL=redis://localhost:6379

# Comportamiento
DEBOUNCE_MS=9000               # ventana de buffer de rafagas por contacto
DEDUP_TTL_SECONDS=86400        # TTL del dedup de wamid
