{
  "name": "loreley-brain",
  "version": "0.1.0",
  "private": true,
  "description": "Cerebro conversacional del asistente virtual de WhatsApp para consultorio de medicina estetica — WhatsApp Cloud API",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:server": "tsx watch src/main/server.ts",
    "dev:worker": "tsx watch src/main/worker.ts",
    "build": "tsc -p tsconfig.json",
    "migrate": "tsx src/main/migrate.ts",
    "reminders": "tsx src/main/reminders.ts",
    "start:server": "tsx src/main/server.ts",
    "start:worker": "tsx src/main/worker.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bullmq": "^5.34.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "eslint": "^9.18.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^5.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.2"
  }
}
